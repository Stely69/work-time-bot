{
  "name": "worktime-bot",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "oxlint",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply worktime-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply worktime-db --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.43.0",
    "hono": "^4.12.21"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260520.1",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.66.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.93.0"
  }
}